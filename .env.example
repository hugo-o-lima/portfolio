# Variáveis lidas pelo docker compose (copie para .env)

# PostgreSQL
POSTGRES_PASSWORD=postgres

# JWT — gere com: openssl rand -hex 64 (mínimo 32 caracteres)
JWT_ACCESS_SECRET=dev_access_secret_change_me_at_least_32_chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_at_least_32_chars

# Admin inicial (criado pelo seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe!SuperStrong123

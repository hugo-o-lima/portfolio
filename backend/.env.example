# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/portfolio_db

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_at_least_32_chars_long_access_secret
JWT_REFRESH_SECRET=change_me_at_least_32_chars_long_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Seed script (only needed when running npm run seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe!SuperStrong123
